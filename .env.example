# Application
NODE_ENV=development
PORT=3000

# JWT
# Use a long random secret in production.
JWT_SECRET=change_this_to_a_long_random_secret_value
JWT_EXPIRY=12h

# OTP / Email
OTP_EXPIRY_MINUTES=5
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password
SMTP_FROM=your_email@example.com

# Security / Reverse proxy
# Comma-separated list of allowed origins.
CORS_ORIGIN=http://localhost:3000
# Set to true only behind HTTPS reverse proxy in production.
FORCE_HTTPS=false

# External MATLAB simulation folder (status/result JSON source)
PROJECT_FILES_PATH=D:\\FPY Application_Files
